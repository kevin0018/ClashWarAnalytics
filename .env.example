# Clash of Clans API Configuration
# Create a file named .env based on this template to store your secrets.

# Your JWT Token obtained from developer.clashofclans.com
# Ensure the IP address matches your current public IP.
COC_API_TOKEN=your_long_jwt_token_here

# List of Clan Tags to track (comma separated)
# Example: #TAG1, #TAG2, #TAG3
CLAN_TAGS=#YOUR_MAIN_CLAN,#YOUR_MINI_CLAN

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get ID from @userinfobot
TELEGRAM_CHAT_ID=your_numeric_chat_id_here